# ============================================================
# IHSG TRADING SYSTEM — Environment Variables
# Rename this file to .env and fill in your values
# ============================================================

# ── LLM Provider ───────────────────────────────────────────
# Options: "groq" | "gemini" | "auto"
# "auto" = Groq as primary, Gemini as fallback on rate-limit
LLM_PROVIDER=auto

# ── Groq API Key (FREE — https://console.groq.com) ─────────
GROQ_API_KEY=your_groq_api_key_here

# ── Google Gemini API Key (FREE — https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Telegram Bot (from @BotFather) — optional, for alerts ──
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Telegram Chat / Channel ID (use @userinfobot) ──────────
TELEGRAM_CHAT_ID=your_chat_id_here
